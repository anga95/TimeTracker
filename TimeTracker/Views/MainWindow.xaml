<Window x:Class="TimeTracker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TimeTracker" Height="600" Width="800">
    <Grid Margin="10" x:Name="RootGrid" FocusManager.IsFocusScope="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Kalendern -->
        <Calendar x:Name="MyCalendar"
          SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
          SelectedDatesChanged="Calendar_SelectedDatesChanged" />

        <!-- Inmatningsfält + lista -->
        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,10,0,0">

            <!-- Inmatningsfält med rubriker -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                    <TextBlock Text="Projektnamn" />
                    <TextBox x:Name="ProjectNameTextBox"
                             Width="150"
                             Text="{Binding NewProjectName}" />
                </StackPanel>
                
                <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                    <TextBlock Text="Arbetade Timmar" />
                    <TextBox Width="80" Text="{Binding NewHoursWorked}" />
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                    <TextBlock Text="Kommentarer" />
                    <TextBox Width="200" Text="{Binding NewComments}" />
                </StackPanel>
                <Button Content="Lägg till" Command="{Binding AddTimeLogEntryCommand}" Width="100" VerticalAlignment="Bottom" />
            </StackPanel>

            <!-- Lista med radera-knapp -->
            <ListView ItemsSource="{Binding TimeLogEntries}" Margin="0,0,0,10">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <TextBlock Text="{Binding ProjectName}" Width="150" />
                            <TextBlock Text="{Binding HoursWorked}" Width="80" />
                            <TextBlock Text="{Binding Comments}" Width="200" />
                            <Button Content="X"
                                Command="{Binding DataContext.DeleteTimeLogEntryCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                CommandParameter="{Binding}"
                                Width="30" Margin="10,0,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Spara & status -->
            <Button Content="Spara" Command="{Binding SaveCommand}" Width="100" Margin="0,0,0,10"/>
            <TextBlock Text="{Binding SaveStatus}" Foreground="Green" />
        </StackPanel>
    </Grid>
</Window>