<Window x:Class="TimeTracker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TimeTracker.Views"
        xmlns:converters="clr-namespace:TimeTracker.Converters"
        Title="TimeTracker" Height="600" Width="800">
    <Window.Resources>
        <converters:DateToBackgroundConverter x:Key="DateToBackgroundConverter" />
        <Style x:Key="CalendarDayButtonStyle" TargetType="CalendarDayButton">
            <Setter Property="Background">
                <Setter.Value>
                    <MultiBinding Converter="{StaticResource DateToBackgroundConverter}">
                        <!-- Binder till datumet för knappen -->
                        <Binding Path="DataContext" RelativeSource="{RelativeSource Self}" />
                        <!-- Binder till listan över slutförda datum -->
                        <Binding Path="DataContext.CompletedDates" RelativeSource="{RelativeSource AncestorType=Window}" />
                        <!-- Binder till listan över ofullständiga datum -->
                        <Binding Path="DataContext.IncompleteDates" RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="55*" />
            <RowDefinition Height="86*" />
        </Grid.RowDefinitions>
        <!-- Kalendern -->
        <Viewbox Stretch="Fill" StretchDirection="UpOnly" Margin="0,0,540,10" Grid.Row="0">
            <Calendar SelectedDate="{Binding SelectedDate}"
              DisplayDateStart="2020-01-01"
              DisplayDateEnd="2030-12-31"
              CalendarDayButtonStyle="{StaticResource CalendarDayButtonStyle}" />
        </Viewbox>
        <!-- Tidloggstabell -->
        <StackPanel Grid.Row="1" Margin="20,54,20,20">
            <DataGrid ItemsSource="{Binding TimeLogEntries}" AutoGenerateColumns="False" CanUserAddRows="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Projektnamn" Binding="{Binding ProjectName}" Width="*" />
                    <DataGridTextColumn Header="Arbetade Timmar" Binding="{Binding HoursWorked}" Width="Auto" />
                    <DataGridTextColumn Header="Kommentarer" Binding="{Binding Comments}" Width="2*" />
                </DataGrid.Columns>
            </DataGrid>
            <Button Content="Spara" Command="{Binding SaveCommand}" Width="100" Margin="0,10,0,0" />
            <TextBlock Text="{Binding SaveStatus}" Foreground="Green" Margin="0,10,0,0" />
        </StackPanel>
    </Grid>
</Window>